# ArgoCD Image Updater Git Credentials Secret
#
# 사용 방법:
# 1. 이 파일을 복사하여 image-updater-git-creds-secret.yaml로 저장
#    cp k8s-helm/releases/argocd/secrets/image-updater-git-creds-secret.yaml.example \
#       k8s-helm/releases/argocd/secrets/image-updater-git-creds-secret.yaml
#
# 2. GitHub Personal Access Token 생성
#    GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
#    → Generate new token (classic)
#    권한: repo (전체)
#
# 3. 아래 YOUR_GITHUB_TOKEN을 실제 토큰으로 교체
#
# 4. Secret 생성
#    kubectl apply -f k8s-helm/releases/argocd/secrets/image-updater-git-creds-secret.yaml
#
# 주의: image-updater-git-creds-secret.yaml은 .gitignore에 추가되어 있으므로
#       실수로 커밋되지 않습니다.

apiVersion: v1
kind: Secret

# 기본 설정
metadata:
  name: argocd-image-updater-git-creds
  namespace: argocd

# 타입
type: Opaque

# 데이터
stringData:
  # GitHub Personal Access Token으로 교체
  username: git
  password: YOUR_GITHUB_TOKEN
