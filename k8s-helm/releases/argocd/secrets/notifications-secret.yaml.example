# ===================================
# ArgoCD Notifications Secret
# 환경별 Discord Webhook 설정
# ===================================
#
# 사용 방법:
# 1. 이 파일을 복사하여 notifications-secret.yaml 생성
#    cp k8s-helm/releases/argocd/secrets/notifications-secret.yaml.example \
#       k8s-helm/releases/argocd/secrets/notifications-secret.yaml
#
# 2. 각 환경의 Discord Webhook URL을 실제 값으로 변경
#
# 3. kubectl apply -f k8s-helm/releases/argocd/secrets/notifications-secret.yaml
#
# 4. .gitignore에 추가하여 보안 유지 (이미 추가되어 있음)
#
# ===================================
#
# 환경별 Discord Webhook URL 생성 방법:
#
# 각 환경마다 별도의 Discord 채널과 Webhook을 생성하세요:
#
# 1. Discord 서버에 환경별 채널 생성
#    - #dev-deployments  (개발 환경)
#    - #stg-deployments  (스테이징 환경)
#    - #prod-deployments (프로덕션 환경)
#
# 2. 각 채널마다 Webhook 생성
#    a. Discord 서버 설정 > 연동 > 웹후크
#    b. '새 웹후크' 클릭
#    c. 웹후크 이름 설정 (예: ArgoCD Dev, ArgoCD Staging, ArgoCD Production)
#    d. 해당 환경의 채널 선택
#    e. '웹후크 URL 복사' 클릭
#    f. 전체 URL을 아래에 입력
#
# URL 형식: https://discord.com/api/webhooks/{webhook_id}/{webhook_token}
#
# ===================================

apiVersion: v1
kind: Secret

# 기본 정보
metadata:
  name: argocd-notifications-secret
  namespace: argocd

# 시크릿 타입
type: Opaque

# 값
stringData:
  # ===================================
  # Dev 환경 Discord Webhook URL (전체 URL)
  # ===================================
  # 예시: https://discord.com/api/webhooks/123456789/dev-webhook-token-here
  discord-dev-webhook: "YOUR_DEV_DISCORD_WEBHOOK_URL_HERE"

  # ===================================
  # Staging 환경 Discord Webhook URL (전체 URL)
  # ===================================
  # 예시: https://discord.com/api/webhooks/987654321/stg-webhook-token-here
  discord-stg-webhook: "YOUR_STG_DISCORD_WEBHOOK_URL_HERE"

  # ===================================
  # Production 환경 Discord Webhook URL (전체 URL)
  # ===================================
  # 예시: https://discord.com/api/webhooks/555666777/prod-webhook-token-here
  discord-prod-webhook: "YOUR_PROD_DISCORD_WEBHOOK_URL_HERE"
