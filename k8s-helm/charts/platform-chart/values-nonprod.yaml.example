# NonProd 환경별 values (Dev + Staging + ArgoCD)

certManager:
  enabled: true
  acmeEmail: "your-email@example.com"  # 🔒 실제 이메일 주소로 변경
  letsencrypt:
    staging:
      enabled: false  # 테스트 시 true, 검증 완료 후 false
    production:
      enabled: true
  # DNS-01 Challenge (Route53)
  route53:
    region: "ap-northeast-2"  # 🔒 실제 AWS Region으로 변경
    hostedZoneID: ""  # 🔒 실제 Route53 Hosted Zone ID로 변경 (선택사항)
    role: ""  # 🔒 실제 IAM Role ARN으로 변경 (IRSA 사용 시)

gateway:
  enabled: true
  createGatewayClass: false
  name: devths-gateway
  namespace: nginx-gateway
  gatewayClassName: nginx

  http:
    enabled: true
    port: 80

  # HTTP to HTTPS 리다이렉트 (301 Permanent Redirect)
  http_redirect:
    enabled: true  # 모든 HTTP 요청을 HTTPS로 리다이렉트

  # 환경별 리스너 (for문으로 순회)
  environments:
    - name: dev
      enabled: true
      tlsSecretName: your-tls-dev
      services:
        - name: web
          hostname: dev.your-domain.com       # 🔒 실제 도메인으로 변경
        - name: api
          hostname: dev.api.your-domain.com   # 🔒 실제 도메인으로 변경
        - name: ai
          hostname: dev.ai.your-domain.com    # 🔒 실제 도메인으로 변경

    - name: stg
      enabled: true
      tlsSecretName: your-tls-stg
      services:
        - name: web
          hostname: stg.your-domain.com       # 🔒 실제 도메인으로 변경
        - name: api
          hostname: stg.api.your-domain.com   # 🔒 실제 도메인으로 변경
        - name: ai
          hostname: stg.ai.your-domain.com    # 🔒 실제 도메인으로 변경

    - name: prod
      enabled: false  # NonProd 환경에서는 비활성화
      tlsSecretName: your-tls-prod
      services:
        - name: web
          hostname: your-domain.com
        - name: api
          hostname: api.your-domain.com
        - name: ai
          hostname: ai.your-domain.com

  # 특수 리스너 (ArgoCD 등)
  listeners:
    argo:
      enabled: true
      domain: nonprod.argo.your-domain.com  # 🔒 실제 도메인으로 변경
      tlsSecretName: your-tls-argo

# 접근 제어 (Access Control)
accessControl:
  enabled: true
  blockedPaths:
    - name: swagger-api-docs
      hostnames:
        - dev.api.your-domain.com  # 🔒 실제 도메인으로 변경
        - stg.api.your-domain.com  # 🔒 실제 도메인으로 변경
      paths:
        - /swagger-ui/
        - /v3/api-docs/

networkPolicy:
  enabled: true

  database:
    rds:
      cidr: "192.168.0.0/16"  # 🔒 실제 RDS CIDR로 변경
    ec2:
      ip: "172.16.10.81/32"   # 🔒 실제 EC2 IP로 변경

  ports:
    frontend: 3000
    backend: 8080
    ai: 8000
    postgres: 5432
    redis: 6379
    rabbitmq: 5672
    dns: 53
    http: 80
    https: 443

  namespaces:
    - name: nginx-gateway
      enabled: true
    - name: dev-app
      enabled: true
    - name: stg-app
      enabled: true

certificates:
  enabled: true
  issuer: letsencrypt-prod  # 또는 letsencrypt-staging

  certs:
    - name: your-tls-dev
      namespace: nginx-gateway
      dnsNames:
        - dev.your-domain.com      # 🔒 실제 도메인으로 변경
        - dev.api.your-domain.com  # 🔒 실제 도메인으로 변경
        - dev.ai.your-domain.com   # 🔒 실제 도메인으로 변경
      enabled: true

    - name: your-tls-stg
      namespace: nginx-gateway
      dnsNames:
        - stg.your-domain.com      # 🔒 실제 도메인으로 변경
        - stg.api.your-domain.com  # 🔒 실제 도메인으로 변경
        - stg.ai.your-domain.com   # 🔒 실제 도메인으로 변경
      enabled: true

    - name: your-tls-argo
      namespace: nginx-gateway
      dnsNames:
        - nonprod.argo.your-domain.com  # 🔒 실제 도메인으로 변경
      enabled: true

externalSecrets:
  enabled: true

  # External Secrets Operator가 AWS 자격 증명을 어디서 얻을지는
  # 운영 방식(IRSA/Pod Identity/노드 역할/secretRef)에 맞게 spec.provider.aws를 조정
  secretStores:
    - kind: ClusterSecretStore
      name: aws-parameter-store
      spec:
        provider:
          aws:
            service: ParameterStore
            region: ap-northeast-2
            # role: arn:aws:iam::123456789012:role/external-secrets-ssm

  # 아래 예시는 SSM Parameter Store 경로 아래의 모든 파라미터를 찾아서 가져옵니다
  # 예: /Dev/BE/ 경로 아래의 모든 파라미터를 찾아 키 이름을 rewrite합니다
  secrets:
    - name: backend-secret-kv
      namespace: dev-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: backend-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - find:
              path: "/Dev/BE"  # 🔒 실제 Parameter Store 경로로 변경
              name:
                regexp: ".*"
              conversionStrategy: "Default"
              decodingStrategy: "None"
            rewrite:
              - regexp:
                  source: "^/Dev/BE/(.*)"  # 🔒 실제 경로에 맞게 변경
                  target: "$1"

    - name: ai-secret-kv
      namespace: dev-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: ai-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - find:
              path: "/Dev/AI"  # 🔒 실제 Parameter Store 경로로 변경
              name:
                regexp: ".*"
              conversionStrategy: "Default"
              decodingStrategy: "None"
            rewrite:
              - regexp:
                  source: "^/Dev/AI/(.*)"  # 🔒 실제 경로에 맞게 변경
                  target: "$1"

    - name: backend-secret-kv
      namespace: stg-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: backend-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - find:
              path: "/Stg/BE"  # 🔒 실제 Parameter Store 경로로 변경
              name:
                regexp: ".*"
              conversionStrategy: "Default"
              decodingStrategy: "None"
            rewrite:
              - regexp:
                  source: "^/Stg/BE/(.*)"  # 🔒 실제 경로에 맞게 변경
                  target: "$1"

    - name: ai-secret-kv
      namespace: stg-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: ai-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - find:
              path: "/Stg/AI"  # 🔒 실제 Parameter Store 경로로 변경
              name:
                regexp: ".*"
              conversionStrategy: "Default"
              decodingStrategy: "None"
            rewrite:
              - regexp:
                  source: "^/Stg/AI/(.*)"  # 🔒 실제 경로에 맞게 변경
                  target: "$1"

argocd:
  imageUpdater:
    restartCronJob:
      enabled: true
      # ECR 토큰은 12시간마다 만료되므로 6시간마다 재시작
      schedule: "0 */6 * * *"
