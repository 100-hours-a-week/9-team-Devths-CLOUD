# NonProd 환경별 values (Dev + Staging + ArgoCD)

certManager:
  enabled: true
  acmeEmail: "your-email@example.com"  # 🔒 실제 이메일 주소로 변경
  letsencrypt:
    staging:
      enabled: false  # 테스트 시 true, 검증 완료 후 false
    production:
      enabled: true

gateway:
  enabled: true
  createGatewayClass: false
  name: devths-gateway
  namespace: nginx-gateway
  gatewayClassName: nginx

  http:
    enabled: true
    port: 80

  # 환경별 리스너 (for문으로 순회)
  environments:
    - name: dev
      enabled: true
      tlsSecretName: your-tls-dev
      services:
        - name: web
          hostname: dev.your-domain.com       # 🔒 실제 도메인으로 변경
        - name: api
          hostname: dev.api.your-domain.com   # 🔒 실제 도메인으로 변경
        - name: ai
          hostname: dev.ai.your-domain.com    # 🔒 실제 도메인으로 변경

    - name: stg
      enabled: true
      tlsSecretName: your-tls-stg
      services:
        - name: web
          hostname: stg.your-domain.com       # 🔒 실제 도메인으로 변경
        - name: api
          hostname: stg.api.your-domain.com   # 🔒 실제 도메인으로 변경
        - name: ai
          hostname: stg.ai.your-domain.com    # 🔒 실제 도메인으로 변경

    - name: prod
      enabled: false  # NonProd 환경에서는 비활성화
      tlsSecretName: your-tls-prod
      services:
        - name: web
          hostname: your-domain.com
        - name: api
          hostname: api.your-domain.com
        - name: ai
          hostname: ai.your-domain.com

  # 특수 리스너 (ArgoCD 등)
  listeners:
    argo:
      enabled: true
      domain: nonprod.argo.your-domain.com  # 🔒 실제 도메인으로 변경
      tlsSecretName: your-tls-argo

networkPolicy:
  enabled: true

  database:
    rds:
      cidr: "192.168.0.0/16"  # 🔒 실제 RDS CIDR로 변경
    ec2:
      ip: "172.16.10.81/32"   # 🔒 실제 EC2 IP로 변경

  ports:
    frontend: 3000
    backend: 8080
    ai: 8000
    postgres: 5432
    redis: 6379
    rabbitmq: 5672
    dns: 53
    http: 80
    https: 443

  namespaces:
    - name: nginx-gateway
      enabled: true
    - name: dev-app
      enabled: true
    - name: stg-app
      enabled: true

certificates:
  enabled: true
  issuer: letsencrypt-prod  # 또는 letsencrypt-staging

  certs:
    - name: your-tls-dev
      namespace: nginx-gateway
      dnsNames:
        - dev.your-domain.com      # 🔒 실제 도메인으로 변경
        - dev.api.your-domain.com  # 🔒 실제 도메인으로 변경
        - dev.ai.your-domain.com   # 🔒 실제 도메인으로 변경
      enabled: true

    - name: your-tls-stg
      namespace: nginx-gateway
      dnsNames:
        - stg.your-domain.com      # 🔒 실제 도메인으로 변경
        - stg.api.your-domain.com  # 🔒 실제 도메인으로 변경
        - stg.ai.your-domain.com   # 🔒 실제 도메인으로 변경
      enabled: true

    - name: your-tls-argo
      namespace: nginx-gateway
      dnsNames:
        - nonprod.argo.your-domain.com  # 🔒 실제 도메인으로 변경
      enabled: true

externalSecrets:
  enabled: true

  # External Secrets Operator가 AWS 자격 증명을 어디서 얻을지는
  # 운영 방식(IRSA/Pod Identity/노드 역할/secretRef)에 맞게 spec.provider.aws를 조정
  secretStores:
    - kind: ClusterSecretStore
      name: aws-parameter-store
      spec:
        provider:
          aws:
            service: ParameterStore
            region: ap-northeast-2
            # role: arn:aws:iam::123456789012:role/external-secrets-ssm

  # 아래 예시는 각 SSM Parameter가 JSON object를 담고 있다고 가정하고 dataFrom.extract를 사용
  # 예: /Dev/Backend 값이 {"SPRING_PROFILES_ACTIVE":"dev","JWT_SECRET":"..."} 형태
  secrets:
    - name: backend-secret-kv
      namespace: dev-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: backend-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - extract:
              key: /Dev/Backend

    - name: ai-secret-kv
      namespace: dev-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: ai-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - extract:
              key: /Dev/AI

    - name: backend-secret-kv
      namespace: stg-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: backend-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - extract:
              key: /Stg/Backend

    - name: ai-secret-kv
      namespace: stg-app
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: aws-parameter-store
          kind: ClusterSecretStore
        target:
          name: ai-secret-kv
          creationPolicy: Owner
          deletionPolicy: Retain
        dataFrom:
          - extract:
              key: /Stg/AI

argocd:
  imageUpdater:
    restartCronJob:
      enabled: true
      # ECR 토큰은 12시간마다 만료되므로 6시간마다 재시작
      schedule: "0 */6 * * *"
