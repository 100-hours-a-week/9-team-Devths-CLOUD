    "list": [
      {
        "name": "path",
        "type": "query",
        "label": "API Path",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"query": "label_values(http_requests_total{job=~\".*ai.*\"}, path)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {}
      },
      {
        "name": "model",
        "type": "query",
        "label": "LLM Model",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"query": "label_values(ai_generation_duration_seconds_count, model)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {}
      }
    ]
  },
