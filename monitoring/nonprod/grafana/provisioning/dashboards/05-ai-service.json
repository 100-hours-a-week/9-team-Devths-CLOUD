      "targets": [{"expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
