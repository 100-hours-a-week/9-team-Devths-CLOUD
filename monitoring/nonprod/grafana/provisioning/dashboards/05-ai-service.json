{
  "title": "05. AI Service",
  "uid": "devths-ai-service",
  "description": "AI 서비스 커스텀 메트릭: HTTP, LLM 생성, VectorDB, Celery, 외부 API, 보안",
  "tags": ["devths", "ai", "fastapi"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "id": null,
  "time": {"from": "now-1h", "to": "now"},
  "graphTooltip": 1,
