# scenarios/loadTest.js를 위한 .env 예시 파일

# ------------------------------------------------------------------------------
# 전역 설정
# ------------------------------------------------------------------------------
# 테스트 실행 환경 (staging, prod 등)
K6_ENV=staging
# 공통 인증 토큰 (필요 시)
K6_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# 환경별 베이스 URL
# ------------------------------------------------------------------------------
# 로컬 개발 환경 URL
K6_DEV_BASE_URL=http://localhost:8080
K6_DEV_AI_BASE_URL=http://localhost:8000
K6_DEV_HEALTH_PATH=/api/health

# 스테이징 환경 URL
K6_STAGING_BASE_URL=https://stg.api.devths.com
K6_STAGING_AI_BASE_URL=https://stg.ai.devths.com
K6_STAGING_HEALTH_PATH=/api/health

# 운영 환경 URL
K6_PROD_BASE_URL=https://api.devths.com
K6_PROD_AI_BASE_URL=https://ai.devths.com
K6_PROD_HEALTH_PATH=/api/health

# ------------------------------------------------------------------------------
# loadTest.js 부하 설정
# ------------------------------------------------------------------------------
# 시작 시 TPS
K6_TPS_START=10
# 목표 최대 TPS
K6_TPS_TARGET=300
# 테스트 지속 시간 (분 단위)
K6_DURATION_MINUTES=10

# 초기 미리 등록할 사용자 수
K6_INITIAL_REGISTER_USER_COUNT=10
# 테스트에 사용할 총 사용자 풀 크기
K6_REGISTER_USER_COUNT=300
# 가입 진행 상황 로그 출력 간격
K6_REGISTER_PROGRESS_LOG_STEP=10
# 사용자당 초기 생성 게시글 수
K6_SEED_POST_COUNT=3
# 테스트 도중 실시간 가입 흐름 활성화 여부
K6_ENABLE_REGISTER_FLOW=true
# 실시간 가입 요청 비율
K6_REGISTER_FLOW_RATE=0.20

# 반복 주기당 요청 수
K6_REQUESTS_PER_ITERATION=5
# 조회(GET) 요청 비율
K6_GET_RATIO=0.7
# 생성/수정(POST) 요청 비율 (비워두면 자동 계산)
K6_POST_RATIO=0.3
# 테스트 대상 GET API 목록
K6_GET_API_LIST=notifications_unread,posts_list,post_detail,comments_list,users_me
# 테스트 대상 POST API 목록
K6_POST_API_LIST=register_flow,posts_like,comments_create,posts_create,posts_update,ai_chat_workflow,ws_chat_workflow

# 게시글 생성 활성화 여부
K6_ENABLE_POST_CREATE=true
# 게시글 생성 요청 비율
K6_POST_CREATE_RATE=0.35
# 게시글 수정 활성화 여부
K6_ENABLE_POST_UPDATE=true
# 게시글 수정 요청 비율
K6_POST_UPDATE_RATE=0.20
# 이미지 첨부 확률
K6_POST_IMAGE_ATTACH_RATE=0.4
# 생성된 게시글 유지 여부
K6_KEEP_CREATED_POST=false
# 게시글 태그 기능 사용 여부
K6_ENABLE_POST_TAGS=false
# 인기 게시글 읽기 부하 활성화 여부
K6_ENABLE_HOT_POST_READ=false
# 부하를 집중할 특정 게시글 ID
K6_HOT_POST_ID=
# 인기 게시글 반복 조회 횟수
K6_HOT_POST_READ_REPEAT=3
# 가상 사용자별 고정 사용자 세션 사용 여부
K6_HOT_POST_STICKY_USER=true
# 인기 게시글(캐시) 조회 비율
K6_HOT_POST_READ_RATIO=1.0
# 일반 게시글(비캐시) 조회 비율
K6_COLD_POST_READ_RATIO=0.0

# AI 채팅 워크플로우 활성화 여부
K6_ENABLE_AI_CHAT=true
# AI 채팅 요청 비율
K6_AI_CHAT_RATE=0.15
# 사용할 AI 모델명
K6_AI_MODEL=GEMINI
# AI 채팅방 유지 여부
K6_KEEP_AI_CHATROOM=false

# 웹소켓 채팅 활성화 여부
K6_ENABLE_WS_CHAT=true
# 웹소켓 채팅 요청 비율
K6_WS_CHAT_RATE=0.15
# 웹소켓 연결 유지 시간(초)
K6_WS_DURATION=8
# 세션당 전송 메시지 수
K6_WS_MESSAGE_COUNT=3
# 메시지 전송 간격(초)
K6_WS_MESSAGE_INTERVAL=2
# 채팅방 유지 여부
K6_KEEP_WS_CHATROOM=false
# 채팅용 가상 사용자 풀 크기
K6_WS_USER_POOL_SIZE=10
# 웹소켓 연결 타임아웃(ms)
K6_WS_CONNECT_TIMEOUT_MS=10000
# SockJS 프로토콜 사용 여부
K6_WS_USE_SOCKJS=true

# 회원가입 시 닉네임 접두어
K6_SIGNUP_NICKNAME_PREFIX=k6
# 회원가입 시 기본 관심사 설정
K6_SIGNUP_INTERESTS=
# 회원가입 재시도 횟수
K6_SIGNUP_MAX_RETRY=3

# ------------------------------------------------------------------------------
# 프로메테우스 연동 (선택 사항)
# ------------------------------------------------------------------------------
# 프로메테우스 리모트 라이트 URL
K6_PROMETHEUS_RW_SERVER_URL=http://localhost:9090/api/v1/write
# 트렌드 데이터를 네이티브 히스토그램으로 전송 여부
K6_PROMETHEUS_RW_TREND_AS_NATIVE_HISTOGRAM=false